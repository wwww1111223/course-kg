<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:course="http://www.example.org/course-kg/1.0/">

    <owl:Ontology rdf:about="http://www.example.org/course-kg/1.0/">
        <rdfs:label>课程知识图谱本体 (Course Knowledge Graph Ontology)</rdfs:label>
        <rdfs:comment>信息组织大作业：课程知识图谱社区系统的概念模型（本体）设计</rdfs:comment>
    </owl:Ontology>

    <!-- ==================== 类定义 ==================== -->

    <!-- 课程类 -->
    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/Course">
        <rdfs:label xml:lang="zh">课程</rdfs:label>
        <rdfs:label xml:lang="en">Course</rdfs:label>
        <rdfs:comment>信息管理学院开设的核心课程</rdfs:comment>
    </owl:Class>

    <!-- 知识点类 -->
    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/KnowledgePoint">
        <rdfs:label xml:lang="zh">知识点</rdfs:label>
        <rdfs:label xml:lang="en">Knowledge Point</rdfs:label>
        <rdfs:comment>课程涵盖的知识单元，使用《汉语主题词表》主题词</rdfs:comment>
    </owl:Class>

    <!-- 分类维度类 -->
    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/Dimension">
        <rdfs:label xml:lang="zh">分类维度</rdfs:label>
        <rdfs:label xml:lang="en">Dimension</rdfs:label>
        <rdfs:comment>知识点的四个分类角度：文化、机构、个人、计算</rdfs:comment>
    </owl:Class>

    <!-- 四个维度的子类 -->
    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/CultureDimension">
        <rdfs:subClassOf rdf:resource="http://www.example.org/course-kg/1.0/Dimension"/>
        <rdfs:label xml:lang="zh">文化维度</rdfs:label>
        <rdfs:comment>涉及文化传统、知识体系、方法论等方面的分类</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/InstitutionDimension">
        <rdfs:subClassOf rdf:resource="http://www.example.org/course-kg/1.0/Dimension"/>
        <rdfs:label xml:lang="zh">机构维度</rdfs:label>
        <rdfs:comment>涉及组织机构、标准体系、行业规范等方面的分类</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/PersonDimension">
        <rdfs:subClassOf rdf:resource="http://www.example.org/course-kg/1.0/Dimension"/>
        <rdfs:label xml:lang="zh">个人维度</rdfs:label>
        <rdfs:comment>涉及个人技能、思维方式、专业素养等方面的分类</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.example.org/course-kg/1.0/ComputingDimension">
        <rdfs:subClassOf rdf:resource="http://www.example.org/course-kg/1.0/Dimension"/>
        <rdfs:label xml:lang="zh">计算维度</rdfs:label>
        <rdfs:comment>涉及计算机技术、算法、系统实现等方面的分类</rdfs:comment>
    </owl:Class>

    <!-- ==================== 属性定义 ==================== -->

    <!-- 课程属性 -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasName">
        <rdfs:label xml:lang="zh">名称</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasNameEn">
        <rdfs:label xml:lang="zh">英文名称</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasCredit">
        <rdfs:label xml:lang="zh">学分</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasCLCNumber">
        <rdfs:label xml:lang="zh">中图法分类号</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>《中国图书馆分类法》分类号</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasDepartment">
        <rdfs:label xml:lang="zh">开课院系</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasTeacher">
        <rdfs:label xml:lang="zh">授课教师</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasDescription">
        <rdfs:label xml:lang="zh">描述</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- 知识点属性 -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasKpName">
        <rdfs:label xml:lang="zh">知识点名称</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasKpDescription">
        <rdfs:label xml:lang="zh">知识点描述</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasSubjectCategory">
        <rdfs:label xml:lang="zh">学科类别</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>知识点所属的学科领域</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- ==================== 关系定义（对象属性） ==================== -->

    <!-- 课程包含知识点 -->
    <owl:ObjectProperty rdf:about="http://www.example.org/course-kg/1.0/hasKnowledgePoint">
        <rdfs:label xml:lang="zh">包含知识点</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:comment>课程包含某个知识点，是系统中的核心关系</rdfs:comment>
    </owl:ObjectProperty>

    <!-- 知识点的上位关系 -->
    <owl:ObjectProperty rdf:about="http://www.example.org/course-kg/1.0/broaderThan">
        <rdfs:label xml:lang="zh">上位关系</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:comment>表示概念间的包含关系，A broaderThan B 表示A是B的上位概念</rdfs:comment>
    </owl:ObjectProperty>

    <!-- 知识点的下位关系（broaderThan的逆关系） -->
    <owl:ObjectProperty rdf:about="http://www.example.org/course-kg/1.0/narrowerThan">
        <rdfs:label xml:lang="zh">下位关系</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:comment>表示概念间的从属关系，A narrowerThan B 表示A是B的下位概念</rdfs:comment>
    </owl:ObjectProperty>

    <!-- 知识点间相关关系 -->
    <owl:ObjectProperty rdf:about="http://www.example.org/course-kg/1.0/relatedTo">
        <rdfs:label xml:lang="zh">相关关系</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:comment>表示概念间的关联关系，非层级关系但语义相关</rdfs:comment>
    </owl:ObjectProperty>

    <!-- 知识点所属维度（字符串枚举：文化 / 机构 / 个人 / 计算） -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/belongsToDimension">
        <rdfs:label xml:lang="zh">所属维度</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/KnowledgePoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>知识点所属的分类维度，取值为字符串枚举：文化 / 机构 / 个人 / 计算</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- 课程间相关关系 -->
    <owl:ObjectProperty rdf:about="http://www.example.org/course-kg/1.0/relatedCourse">
        <rdfs:label xml:lang="zh">课程相关</rdfs:label>
        <rdfs:domain rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:range rdf:resource="http://www.example.org/course-kg/1.0/Course"/>
        <rdfs:comment>课程之间的相关关系，基于共享知识点建立</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ==================== 关系约束 ==================== -->

    <!-- HAS_KNOWLEDGE 的重要程度属性 -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasImportance">
        <rdfs:label xml:lang="zh">重要程度</rdfs:label>
        <rdfs:comment>知识点对课程的重要程度：high/medium/low</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- RELATED_COURSE 的原因属性 -->
    <owl:DatatypeProperty rdf:about="http://www.example.org/course-kg/1.0/hasReason">
        <rdfs:label xml:lang="zh">关联原因</rdfs:label>
        <rdfs:comment>课程间相关关系的原因说明</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

</rdf:RDF>
